<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LinuxDemo.MainPage"
             Title="MAUI on Linux — widget gallery">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="20">

            <!-- ============================================================ -->
            <!-- Header                                                       -->
            <!-- ============================================================ -->
            <Label Text="🐧 .NET MAUI on Linux"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="The exact same XAML below is rendered natively on every platform you build for — GTK4 on Linux, AppKit on macOS, WinUI on Windows, and so on."
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   TextColor="Gray" />

            <!-- ============================================================ -->
            <!-- Card 1 — device / runtime info                               -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="🖥  Device" FontAttributes="Bold" FontSize="16" />
                    <Label x:Name="PlatformLabel" />
                    <Label x:Name="RuntimeLabel" />
                    <Label x:Name="DisplayLabel" />
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 2 — Button + counter                                    -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🖱  Button + counter" FontAttributes="Bold" FontSize="16" />
                    <Button x:Name="CounterBtn"
                            Text="Click me"
                            Clicked="OnCounterClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 3 — Slider + live preview                               -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🎚  Mood slider" FontAttributes="Bold" FontSize="16" />
                    <Label x:Name="MoodLabel" Text="How's the build going? 😐" />
                    <Slider x:Name="MoodSlider"
                            Minimum="0" Maximum="100" Value="50"
                            ValueChanged="OnMoodChanged" />
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 4 — RGB color mixer                                     -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🎨  RGB color mixer" FontAttributes="Bold" FontSize="16" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="R" VerticalOptions="Center" />
                        <Slider Grid.Row="0" Grid.Column="1" x:Name="RedSlider"
                                Minimum="0" Maximum="255" Value="80"
                                ValueChanged="OnColorChanged" />
                        <Label Grid.Row="1" Grid.Column="0" Text="G" VerticalOptions="Center" />
                        <Slider Grid.Row="1" Grid.Column="1" x:Name="GreenSlider"
                                Minimum="0" Maximum="255" Value="43"
                                ValueChanged="OnColorChanged" />
                        <Label Grid.Row="2" Grid.Column="0" Text="B" VerticalOptions="Center" />
                        <Slider Grid.Row="2" Grid.Column="1" x:Name="BlueSlider"
                                Minimum="0" Maximum="255" Value="212"
                                ValueChanged="OnColorChanged" />
                    </Grid>
                    <Border x:Name="ColorPreview"
                            HeightRequest="60"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="#512BD4">
                        <Label x:Name="HexLabel"
                               Text="#512BD4"
                               TextColor="White"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 5 — Stepper + ProgressBar + ActivityIndicator           -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🛠  Build simulator" FontAttributes="Bold" FontSize="16" />
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                        <Label Grid.Column="0"
                               x:Name="StepperLabel"
                               Text="Parallel jobs: 4"
                               VerticalOptions="Center" />
                        <Stepper Grid.Column="1"
                                 x:Name="JobsStepper"
                                 Minimum="1" Maximum="16" Value="4" Increment="1"
                                 ValueChanged="OnJobsChanged" />
                    </Grid>
                    <ProgressBar x:Name="BuildProgress" Progress="0" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                x:Name="RunBuildBtn"
                                Text="dotnet build"
                                Clicked="OnRunBuildClicked" />
                        <ActivityIndicator Grid.Column="1"
                                           x:Name="BuildSpinner"
                                           IsRunning="False" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 7 — Date + Time pickers                                 -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📅  Schedule a nightly build" FontAttributes="Bold" FontSize="16" />
                    <DatePicker x:Name="ScheduleDate" DateSelected="OnScheduleChanged" />
                    <TimePicker x:Name="ScheduleTime" PropertyChanged="OnScheduleTimeChanged" />
                    <Label x:Name="ScheduleLabel"
                           FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 8 — Entry + Editor                                      -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="⌨  Text input" FontAttributes="Bold" FontSize="16" />
                    <Entry x:Name="NameEntry"
                           Placeholder="Your name"
                           TextChanged="OnNameChanged" />
                    <Editor x:Name="NotesEditor"
                            Placeholder="Notes for the audience…"
                            HeightRequest="80"
                            AutoSize="TextChanges" />
                    <Label x:Name="GreetingLabel" FontAttributes="Italic" />
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 9 — CollectionView of Linux distros                     -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🧱  CollectionView — pick your flavor" FontAttributes="Bold" FontSize="16" />
                    <CollectionView x:Name="DistrosView"
                                    SelectionMode="Single"
                                    SelectionChanged="OnDistroSelected"
                                    HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="6,8" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="{Binding Emoji}" FontSize="22" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding Tagline}" FontSize="12" TextColor="Gray" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label x:Name="DistroLabel" FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- ============================================================ -->
            <!-- Card 10 — CarouselView with tips                             -->
            <!-- ============================================================ -->
            <Border Stroke="Gray" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🎠  CarouselView — swipe the tips" FontAttributes="Bold" FontSize="16" />
                    <CarouselView x:Name="TipsCarousel"
                                  HeightRequest="120"
                                  IndicatorView="TipsIndicator">
                        <CarouselView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#512BD4" StrokeShape="RoundRectangle 10" Padding="14" Margin="6,0">
                                    <Label Text="{Binding .}"
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>
                    <IndicatorView x:Name="TipsIndicator"
                                   IndicatorColor="LightGray"
                                   SelectedIndicatorColor="#512BD4"
                                   HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
